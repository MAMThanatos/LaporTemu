<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LaporTemu" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/bg_light</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Customize colors for Material Components -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Bottom Navigation Indicator (Pill) - Make it transparent to remove -->
        <item name="colorPrimaryContainer">@android:color/transparent</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>
    </style>

    <style name="Theme.LaporTemu" parent="Base.Theme.LaporTemu" />
</resources>